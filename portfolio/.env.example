# ============================================================
# Portfolio — EmailJS Environment Variables
# Copy this file to .env and fill in your real values.
# Get your credentials at https://www.emailjs.com
# NEVER commit .env to version control.
# In Netlify: Site settings → Environment variables → add all 3
# ============================================================

# Your EmailJS Public Key  (Account → API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# The Service ID connected to your email provider (e.g. Gmail)
# Dashboard → Email Services → your service
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# The Template ID for the owner notification email
# Dashboard → Email Templates → your template
# Required template variables:
#   {{from_name}}   — Sender's full name
#   {{from_email}}  — Sender's email address
#   {{from_phone}}  — Sender's phone number
#   {{subject}}     — Subject (optional, may be empty)
#   {{message}}     — Message body
#   {{sent_date}}   — Date & time of submission (auto-set)
#   {{owner_email}} — Your email address (auto-set)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
